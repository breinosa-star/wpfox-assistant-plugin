{
  "name": "kbfox",
  "version": "1.0.0",
  "description": "KBFox — AI-powered chatbot and knowledge base for WordPress",
  "private": true,
  "scripts": {
    "build": "esbuild src/chat-widget.js --bundle --minify --outfile=assets/dist/grayfox-chat.min.js",
    "build:css": "esbuild src/styles/widget.css --bundle --minify --outfile=assets/dist/grayfox-chat.min.css",
    "build:admin": "esbuild src/styles/admin.css --bundle --minify --outfile=assets/dist/grayfox-admin.min.css",
    "build:prompts": "node scripts/build-prompts.js",
    "build:all": "npm run build:prompts && npm run build && npm run build:css && npm run build:admin",
    "package": "node scripts/package-plugin.js",
    "package:dry": "node scripts/package-plugin.js --dry-run",
    "validate": "node scripts/validate.js",
    "validate:zip": "node scripts/validate.js --zip",
    "watch": "esbuild src/chat-widget.js --bundle --watch --outfile=assets/dist/grayfox-chat.min.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:happy": "playwright test --grep \"Happy Path\"",
    "test:e2e:edge": "playwright test --grep \"Edge Cases\"",
    "test:e2e:report": "playwright show-report tests/e2e/report",
    "test:remote": "playwright test --config playwright.remote.config.js",
    "test:remote:headed": "playwright test --config playwright.remote.config.js --headed",
    "check:ip": "node scripts/check-ip-status.js",
    "docker:up": "docker compose -f tests/docker-compose.yml up -d",
    "docker:setup": "docker compose -f tests/docker-compose.yml run --rm setup",
    "docker:down": "docker compose -f tests/docker-compose.yml down",
    "docker:reset": "docker compose -f tests/docker-compose.yml down -v"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "esbuild": "0.24.0"
  }
}
